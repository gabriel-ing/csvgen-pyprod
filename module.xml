<?xml version="1.0" encoding="UTF-8"?>
<Export generator="Cache" version="25">
  <Document name="csvgen-prod.ZPM">
    <Module>
      <Name>csvgen-prod</Name>
      <Version>1.0.0</Version>
      <Description>CSV to Table production using intersystems-pyprod</Description>
      <Author>
        <Person>Gabriel Ing</Person>
        <Organization>InterSystems</Organization>
        <CopyrightDate>2026</CopyrightDate>
        <License>MIT</License>
      </Author>
      <Packaging>module</Packaging>
      <SystemRequirements Version=">=2024.1" Interoperability="enabled"/>
      <Defaults>
        <Parameter Name="ExtraPipFlags">--upgrade</Parameter>
      </Defaults>
      <Default Name="envSetup" Value="0"/>
      <Default Name="fileWatcherRoot" Value="${libdir}/csvgen_pyprod"/>
      <SourcesRoot>src</SourcesRoot>

      <!-- Deploy Python source so it is importable as the csvgen_pyprod package -->
      <FileCopy Name="src/csvgen_pyprod/" Target="${libdir}/csvgen_pyprod/"/>

      <Resource Name="Setup.ProductionSetup.cls"/>

      <!-- Run production setup after all resources are activated -->
      <!-- Pass -DenvSetup=1 at install time to also run environment setup -->
      <Invoke Class="Setup.ProductionSetup" Method="Setup" Phase="Activate" When="After" CheckStatus="true">
        <Arg>${fileWatcherRoot}</Arg>
        <Arg>${envSetup}</Arg>
      </Invoke>

      <AfterInstallMessage>CSVGen installed. Configure inbound/working/archive directories on each host item, then start the production from the Management Portal or via: do ##class(Setup.ProductionSetup).Start()</AfterInstallMessage>
    </Module>
  </Document>
</Export>
